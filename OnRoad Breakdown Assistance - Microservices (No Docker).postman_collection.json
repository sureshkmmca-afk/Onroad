            "body": {
              "mode": "raw",
              "raw": "{\n  \"mechanicId\": 1,\n  \"vehicleNumber\": \"KA01AB1234\",\n  \"issueDescription\": \"Engine overheating and smoke coming\",\n  \"breakdownLocation\": \"Bangalore - Silk Board\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
