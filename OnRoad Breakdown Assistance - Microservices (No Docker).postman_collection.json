              "raw": "{{baseUrl}}/requests/api/v1/requests/me?as=USER",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "requests",
                "api",
                "v1",
                "requests",
                "me"
              ],
              "query": [
                {
                  "key": "as",
                  "value": "USER"
